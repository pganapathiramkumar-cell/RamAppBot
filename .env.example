# ─── API Gateway ────────────────────────────────────────────
API_GATEWAY_PORT=8000
API_GATEWAY_HOST=0.0.0.0
ENVIRONMENT=development

# ─── Auth Service ────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rambot
POSTGRES_USER=rambot_user
POSTGRES_PASSWORD=rambot_pass

# Steer Service DB
STEER_DB_URL=postgresql+asyncpg://rambot_user:rambot_pass@localhost:5432/steer_db

# Skill Service DB
SKILL_DB_URL=postgresql+asyncpg://rambot_user:rambot_pass@localhost:5432/skill_db

# Auth Service DB
AUTH_DB_URL=postgresql+asyncpg://rambot_user:rambot_pass@localhost:5432/auth_db

# ─── Redis (Cache + Sessions) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ─── Message Broker (RabbitMQ / Kafka) ──────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── AI / LLM ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096

# ─── AWS ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=rambot-assets

# ─── Push Notifications ──────────────────────────────────────
FCM_SERVER_KEY=your-firebase-server-key
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=
DATADOG_API_KEY=
LOG_LEVEL=INFO

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_ENV=development
